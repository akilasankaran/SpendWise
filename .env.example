# MongoDB connection string (Atlas or local)
# Local dev — use a separate database from production:
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/spendwise-dev?retryWrites=true&w=majority

# Production (set in Vercel dashboard only — use database name "spendwise"):
# MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/spendwise?retryWrites=true&w=majority

# Auth.js — generate secret with: openssl rand -base64 32
AUTH_SECRET=your-auth-secret-here

# Local
AUTH_URL=http://localhost:3000

# Production (Vercel) — set to your deployed URL, e.g. https://spendwise.vercel.app
# AUTH_URL=https://your-app.vercel.app
